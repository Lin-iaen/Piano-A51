                      13     ; Delay_ms
                      14     ; Input : R7 = delay time in milliseconds
                      15     ; Clock : 11.0592MHz (1 machine cycle = 12 / 11.0592MHz = 1.085us)
                      16     ; Note  : 1ms loop is calibrated to about 1003.7us.
0000                  17     Delay_ms:
0000 C0E0             18             PUSH    ACC
0002 C005             19             PUSH    05H ;PUSHеҸӘиғҪж“ҚдҪңзӣҙжҺҘең°еқҖ,дёҚиғҪеҶҷжҲҗPUSH R5, PUSH R6, PUSH R7
0004 C006             20             PUSH    06H
0006 C007             21             PUSH    07H
                      22     
0008 EF               23             MOV     A, R7
0009 600A             24             JZ      Delay_ms_Exit ; JZ (Jump if Zero) жҢҮд»ӨдјҡжЈҖжҹҘ A еҜ„еӯҳеҷЁзҡ„еҖјпјҢдё”еҸ
                             ӘдјҡеҺ»жЈҖжөӢзҙҜеҠ еҷЁA
                      25             
                      26     
                      27     
                      28     
                      29     
                      30     
                      31     
                      32     
000B                  33     Delay_ms_Loop:
000B 7D02             34             MOV     R5, #02H ; 1MC = 1.085us, 1ms = 1000us, 1000/1.085 вүҲ 921.66
                      35     
000D                  36     Delay_ms_L1:
000D 7EE5             37             MOV     R6, #0E5H ; 2MC
                      38     
000F                  39     Delay_ms_L2:
000F DEFE             40             DJNZ    R6, Delay_ms_L2 ; еҶ…еұӮеҫӘзҺҜпјҢж¶ҲиҖ— 2MC * 229 = 458MC
0011 DDFA             41             DJNZ    R5, Delay_ms_L1 ; еӨ–еұӮеҫӘзҺҜпјҢж¶ҲиҖ— 2 * 458MC = 916MC , жҗӯй…ҚеүҚйқўзҡ„
                             PUSHе’ҢDJNZжҢҮд»Өзҡ„ж¶ҲиҖ—(16MC)пјҢи°ғз”ЁLCALLе’ҢRETж¶ҲиҖ—4MC , MOV Aе’ҢJZ = 1+2 = 3MC , ж•
                             ҙдёӘеҫӘзҺҜеӨ§зәҰжҳҜ 916 + 16 + 4 + 3 = 939MCпјҢ939 * 1.085us вүҲ 1019.7usпјҢеӨ§зәҰжҳҜ1msзҡ„е»¶ж—¶гҖӮ
0013 DFF6             42             DJNZ    R7, Delay_ms_Loop
                      43     
0015                  44     Delay_ms_Exit:
0015 D007             45             POP     07H
0017 D006             46             POP     06H
0019 D005             47             POP     05H
001B D0E0             48             POP     ACC
