0023 85008A   F       60             MOV     TL0, Freq_TL0
0026 D28C             61             SETB    TR0
0028 8004             62             SJMP    Buzzer_Exit
                      63     
002A                  64     Buzzer_Mute:
002A C28C             65             CLR     TR0 ; 停止定时器0
