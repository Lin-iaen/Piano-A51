0036 22               73             RET
                      74     
                      75     ; 11.0592MHz crystal
                      76     ; Timer tick = 12/11.0592MHz = 1.085us
                      77     ; Reload = 65536 - round(460800 / f)
                      78     ; Index: 0=rest, 1..7 low(C3..B3), 8..14 middle(C4..B4), 15..21 high(C5..B5)
                      79     ; 初值计算公式 : (65536 - 初值) * 2f = 11.0592MHz / 12 = 921600
                      80     
